# Copia questo file in .env.local e riempi con le TUE chiavi reali.
# .env.local NON va mai committato su GitHub (vedi .gitignore).

# --- Gemini (SOLO lato server, mai NEXT_PUBLIC) ---
GEMINI_API_KEY=INSERISCI_QUI_LA_NUOVA_CHIAVE_RIGENERATA

# --- Firebase (config pubblica lato client, protetta dalle Security Rules) ---
# Prendi questi valori da Firebase Console → Impostazioni progetto → App web.
NEXT_PUBLIC_FIREBASE_API_KEY=INSERISCI_QUI
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=INSERISCI_QUI.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=INSERISCI_QUI
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=INSERISCI_QUI.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=INSERISCI_QUI
NEXT_PUBLIC_FIREBASE_APP_ID=INSERISCI_QUI
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=INSERISCI_QUI

# --- Firebase Admin (SOLO lato server, per verificare gli utenti loggati) ---
# Firebase Console → Impostazioni progetto → Account di servizio → Genera nuova chiave privata.
#
# Modo consigliato: incolla l'intero JSON della service account codificato in
# base64 (una singola riga, impossibile da rompere col copia-incolla):
FIREBASE_SERVICE_ACCOUNT_BASE64=INSERISCI_QUI

# In alternativa, le stesse informazioni separate in 3 variabili (piu' fragile
# perche' FIREBASE_ADMIN_PRIVATE_KEY e' multi-riga):
FIREBASE_ADMIN_PROJECT_ID=INSERISCI_QUI
FIREBASE_ADMIN_CLIENT_EMAIL=INSERISCI_QUI
FIREBASE_ADMIN_PRIVATE_KEY="INSERISCI_QUI_CON_\n_MANTENUTI"

# --- Google AdSense ---
NEXT_PUBLIC_ADSENSE_CLIENT_ID=ca-pub-XXXXXXXXXXXXXXXX

# --- SEO (usato in robots.txt/sitemap.xml) ---
# Il dominio pubblico del sito (senza slash finale), es. https://tesinafacile.vercel.app
NEXT_PUBLIC_SITE_URL=https://tesinafacile.vercel.app
